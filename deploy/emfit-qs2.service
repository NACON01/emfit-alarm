[Unit]
Description=Emfit QS2 API
After=network.target

[Service]
Type=simple
User=okazaki
WorkingDirectory=/home/okazaki/emfit-alarm/emfit-api
EnvironmentFile=/home/okazaki/emfit-alarm/deploy/emfit.env
ExecStart=/usr/bin/python3 -m qs2.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target